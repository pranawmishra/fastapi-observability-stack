local.file_match "fastapi_logs" {
  path_targets = [
    {
      __path__ = "/logs/*.log",
      job = "fastapi",
    },
  ]
}

loki.source.file "fastapi" {
  targets    = local.file_match.fastapi_logs.targets
  forward_to = [loki.write.default.receiver]
}

loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}